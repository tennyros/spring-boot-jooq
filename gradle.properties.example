# Example gradle.properties
# Replace these values with actual ones in your local gradle.properties file

# jdbc block
postgres.driver=org.dbms.Driver
postgres.url=jdbc:postgresql://localhost:5432/mydb
postgres.username=username
postgres.password=password

# generator block
jooq.generator.name=org.jooq.codegen.JavaGenerator
jooq.database.name=org.jooq.meta.dbms.Database
jooq.database.input_schema=schema
jooq.database.includes=username
jooq.target.package=com.example.generated
jooq.target.directory=path/to/target/directory